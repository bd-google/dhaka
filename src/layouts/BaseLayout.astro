---
import { siteMeta } from '../data/siteMeta';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: URL;
  noindex?: boolean;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  ogImage = siteMeta.image,
  ogType = siteMeta.type,
  canonicalUrl = Astro.url,
  noindex = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={siteMeta.favicon} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={siteMeta.themeColor} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />

    <!-- Twitter -->
    <meta name="twitter:card" content={siteMeta.twitter.card} />
    <meta name="twitter:site" content={siteMeta.twitter.site} />
    <meta name="twitter:creator" content={siteMeta.twitter.creator} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <slot name="schema" />
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
