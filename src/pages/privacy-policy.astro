---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/siteMeta';

const title = `Privacy Policy | ${siteMeta.businessName}`;
const description = `How ${siteMeta.businessName} collects, uses, and protects information from visitors and clients.`;
---

<BaseLayout title={title} description={description} noindex={true}>
  <section style="padding: 80px 0;">
    <div class="container" style="max-width: 750px;">
      <h1 style="font-size: clamp(2rem, 6vw, 3rem); margin-bottom: 16px;">Privacy Policy</h1>
      <p style="color: var(--accent-color); font-size: 0.9rem; margin-bottom: 40px;">
        ⚠ Draft structure only — not reviewed by a lawyer. Replace each section
        below with real, legally-reviewed content before removing noindex and
        publishing this page.
      </p>

      <h2 style="font-size: 1.2rem; margin-top: 30px;">1. What information we collect</h2>
      <p>[Placeholder — e.g. contact form submissions, email correspondence, company verification data.]</p>

      <h2 style="font-size: 1.2rem; margin-top: 30px;">2. How we use it</h2>
      <p>[Placeholder — e.g. to respond to inquiries, to perform verification services, to maintain records.]</p>

      <h2 style="font-size: 1.2rem; margin-top: 30px;">3. How we store and protect it</h2>
      <p>[Placeholder]</p>

      <h2 style="font-size: 1.2rem; margin-top: 30px;">4. Third parties</h2>
      <p>[Placeholder — e.g. whether data is shared with factories, buyers, or government bodies during verification.]</p>

      <h2 style="font-size: 1.2rem; margin-top: 30px;">5. Your rights</h2>
      <p>[Placeholder — e.g. how someone can request their data be corrected or deleted.]</p>

      <h2 style="font-size: 1.2rem; margin-top: 30px;">6. Contact</h2>
      <p>Questions about this policy: <a href={`mailto:${siteMeta.contact.email}`}>{siteMeta.contact.email}</a></p>
    </div>
  </section>
</BaseLayout>
