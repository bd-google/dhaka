---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/siteMeta';

// PLACEHOLDER PAGE — slug/name/content to be finalized later.
const title = `FAQ | ${siteMeta.businessName}`;
const description = `Common questions about working with ${siteMeta.businessName} on Bangladesh garment and textile sourcing, verification, and market entry.`;

const faqs = [
  { q: '[Placeholder question 1]', a: '[Placeholder answer.]' },
  { q: '[Placeholder question 2]', a: '[Placeholder answer.]' },
  { q: '[Placeholder question 3]', a: '[Placeholder answer.]' },
];
---

<BaseLayout title={title} description={description}>
  <section style="padding: 80px 0;">
    <div class="container" style="max-width: 800px;">
      <h1 style="font-size: clamp(2rem, 6vw, 3rem); margin-bottom: 24px;">Frequently Asked Questions</h1>
      {faqs.map(item => (
        <div style="margin-bottom: 28px; padding-bottom: 28px; border-bottom: 1px solid var(--border-color);">
          <h2 style="font-size: 1.1rem; margin-bottom: 8px;">{item.q}</h2>
          <p>{item.a}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
