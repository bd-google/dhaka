---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const pillarPosts = allPosts.filter(p => p.data.isPillar).sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const buyerPillars = pillarPosts.filter(p => ['factory-verification', 'low-moq', 'feasibility', 'sample-process', 'production-monitoring', 'quality-inspection', 'shipping', 'first-time-buyer', 'manufacturing-cost', 'knitwear-sourcing', 'compliance-certification', 'sustainable-sourcing', 'tech-pack', 'denim-sourcing', 'activewear-sourcing', 'kidswear-sourcing', 'woven-sourcing', 'sweater-sourcing', 'lingerie-sourcing', 'workwear-sourcing', 'home-textile-sourcing', 'sourcing-red-flags', 'factory-operational-risks', 'uflpa-cotton-traceability', 'environmental-compliance', 'buyer-considerations', 'production-role-problems'].includes(p.data.cluster));
const supplierPillars = pillarPosts.filter(p => ['local-rep', 'selling-bangladesh', 'business-setup', 'trade-show', 'machinery-support', 'component-suppliers', 'fabric-yarn-gap', 'payment-collection', 'risk-analysis', 'sample-distribution', 'strategic-sourcing', 'training-coordination', 'foreign-entry-barriers', 'foreign-entry-success'].includes(p.data.cluster));
const factoryPillars = pillarPosts.filter(p => ['factory-buyer-access', 'factory-digital-presence', 'factory-documentation', 'factory-growth'].includes(p.data.cluster));

function getSlug(post: any) {
  let slug = post.id.split('/').pop()?.replace('.md', '');
  if (slug === 'pillar') {
    slug = post.id.split('/')[1];
  }
  return slug;
}
---

<BaseLayout title="Industry Insights & Guides | ThreadBridge BD Blog" description="Expert advice on garment sourcing, factory verification, and textile market entry in Bangladesh.">
  <div class="container" style="padding-top: 60px;">
    <header style="margin-bottom: 40px; text-align: center;">
      <h1 style="font-size: 3rem; margin-bottom: 20px;">Bangladesh Sourcing Insights</h1>
      <p style="font-size: 1.25rem; max-width: 700px; margin: 0 auto;">Deep-dive guides on manufacturing, quality control, and market entry from people on the ground in Dhaka.</p>
    </header>

    <div style="max-width: 500px; margin: 0 auto 80px; padding: 24px 28px; border: 1px solid var(--border-color); border-radius: 10px; text-align: center;">
      <h2 style="font-size: 1rem; margin-bottom: 8px;">Get new guides by email</h2>
      <p style="font-size: 0.9rem; margin-bottom: 16px;">New sourcing insights and real-time updates (like currency/LC disruptions or gas crisis impacts) as they happen — no spam, unsubscribe anytime.</p>
      <form action="https://api.web3forms.com/submit" method="POST" style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;">
        <input type="hidden" name="access_key" value="" />
        <input type="hidden" name="subject" value="New newsletter signup" />
        <input type="email" name="email" required placeholder="you@company.com" style="flex: 1; min-width: 200px; padding: 10px 14px; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 6px; color: var(--text-primary);" />
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
    </div>

    <section style="margin-bottom: 80px;">
      <h2 style="font-size: 2rem; margin-bottom: 40px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">For Clothing Brands & Buyers</h2>
      <div class="grid grid-2-tablet grid-3-desktop">
        {buyerPillars.map(post => (
          <a href={`/blog/${getSlug(post)}`} class="blog-card">
            <span class="date">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="read-more">Read Guide →</span>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 style="font-size: 2rem; margin-bottom: 40px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">For Textile & Machinery Suppliers</h2>
      <div class="grid grid-2-tablet grid-3-desktop">
        {supplierPillars.map(post => (
          <a href={`/blog/${getSlug(post)}`} class="blog-card">
            <span class="date">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="read-more">Read Guide →</span>
          </a>
        ))}
      </div>
    </section>
    <section style="margin-bottom: 80px;">
      <h2 style="font-size: 2rem; margin-bottom: 40px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">For Bangladeshi Factories</h2>
      <div class="grid grid-2-tablet grid-3-desktop">
        {factoryPillars.map(post => (
          <a href={`/blog/${getSlug(post)}`} class="blog-card">
            <span class="date">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="read-more">Read Guide →</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .blog-card {
    display: block;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    padding: 30px;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
    height: 100%;
  }
  .blog-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-4px);
  }
  .date {
    display: block;
    font-size: 0.8rem;
    color: var(--accent-color);
    margin-bottom: 12px;
    font-weight: 700;
    text-transform: uppercase;
  }
  h3 {
    font-size: 1.25rem;
    margin-bottom: 16px;
    color: var(--text-primary);
    line-height: 1.4;
  }
  p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }
  .read-more {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent-color);
  }
</style>
