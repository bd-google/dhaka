---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const pillarPosts = allPosts.filter(p => p.data.isPillar).sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const buyerPillars = pillarPosts.filter(p => ['factory-verification', 'low-moq', 'feasibility', 'sample-process', 'production-monitoring', 'quality-inspection', 'shipping', 'first-time-buyer', 'manufacturing-cost', 'knitwear-sourcing', 'compliance-certification', 'sustainable-sourcing', 'tech-pack', 'denim-sourcing'].includes(p.data.cluster));
const supplierPillars = pillarPosts.filter(p => ['local-rep', 'selling-bangladesh', 'business-setup', 'trade-show', 'machinery-support'].includes(p.data.cluster));
const factoryPillars = pillarPosts.filter(p => ['factory-buyer-access'].includes(p.data.cluster));

function getSlug(post: any) {
  let slug = post.id.split('/').pop()?.replace('.md', '');
  if (slug === 'pillar') {
    slug = post.id.split('/')[1];
  }
  return slug;
}
---

<BaseLayout title="Industry Insights & Guides | ThreadBridge BD Blog" description="Expert advice on garment sourcing, factory verification, and textile market entry in Bangladesh.">
  <div class="container" style="padding-top: 60px;">
    <header style="margin-bottom: 60px; text-align: center;">
      <h1 style="font-size: 3rem; margin-bottom: 20px;">Bangladesh Sourcing Insights</h1>
      <p style="font-size: 1.25rem; max-width: 700px; margin: 0 auto;">Deep-dive guides on manufacturing, quality control, and market entry from people on the ground in Dhaka.</p>
    </header>

    <section style="margin-bottom: 80px;">
      <h2 style="font-size: 2rem; margin-bottom: 40px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">For Clothing Brands & Buyers</h2>
      <div class="grid grid-2-tablet grid-3-desktop">
        {buyerPillars.map(post => (
          <a href={`/blog/${getSlug(post)}`} class="blog-card">
            <span class="date">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="read-more">Read Guide →</span>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 style="font-size: 2rem; margin-bottom: 40px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">For Textile & Machinery Suppliers</h2>
      <div class="grid grid-2-tablet grid-3-desktop">
        {supplierPillars.map(post => (
          <a href={`/blog/${getSlug(post)}`} class="blog-card">
            <span class="date">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="read-more">Read Guide →</span>
          </a>
        ))}
      </div>
    </section>
    <section style="margin-bottom: 80px;">
      <h2 style="font-size: 2rem; margin-bottom: 40px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">For Bangladeshi Factories</h2>
      <div class="grid grid-2-tablet grid-3-desktop">
        {factoryPillars.map(post => (
          <a href={`/blog/${getSlug(post)}`} class="blog-card">
            <span class="date">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="read-more">Read Guide →</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .blog-card {
    display: block;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    padding: 30px;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
    height: 100%;
  }
  .blog-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-4px);
  }
  .date {
    display: block;
    font-size: 0.8rem;
    color: var(--accent-color);
    margin-bottom: 12px;
    font-weight: 700;
    text-transform: uppercase;
  }
  h3 {
    font-size: 1.25rem;
    margin-bottom: 16px;
    color: var(--text-primary);
    line-height: 1.4;
  }
  p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }
  .read-more {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent-color);
  }
</style>
