---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/siteMeta';

// PLACEHOLDER PAGE — slug/name/content to be finalized later.
const title = `Who We Work With | ${siteMeta.businessName}`;
const description = `The types of foreign buyers and foreign suppliers ${siteMeta.businessName} typically works with in Bangladesh's garment and textile industry.`;
---

<BaseLayout title={title} description={description}>
  <section style="padding: 80px 0;">
    <div class="container" style="max-width: 800px;">
      <h1 style="font-size: clamp(2rem, 6vw, 3rem); margin-bottom: 24px;">Who We Work With</h1>

      <h2 style="font-size: 1.3rem; margin-top: 20px;">Foreign buyers</h2>
      <p>[Placeholder — brands/importers sourcing garments from Bangladesh who need verification, monitoring, or on-ground representation.]</p>

      <h2 style="font-size: 1.3rem; margin-top: 30px;">Foreign suppliers</h2>
      <p>[Placeholder — fabric, machinery, and accessories suppliers, especially from China, Hong Kong, Taiwan, and Turkey, trying to sell into the Bangladeshi market.]</p>

      <div style="margin-top: 40px;">
        <a href="/contact" class="btn btn-primary">Talk to us</a>
      </div>
    </div>
  </section>
</BaseLayout>
