---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/siteMeta';

const title = `Page Not Found | ${siteMeta.businessName}`;
const description = "The page you're looking for doesn't exist or may have moved.";
---

<BaseLayout title={title} description={description} noindex={true}>
  <section style="padding: 100px 0; text-align: center;">
    <div class="container" style="max-width: 600px;">
      <p class="eyebrow">404</p>
      <h1 style="font-size: clamp(1.8rem, 5vw, 2.5rem); margin-bottom: 16px;">Page not found</h1>
      <p style="margin-bottom: 32px;">
        The page you're looking for doesn't exist, or it may have moved. Here are some places to go instead:
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/companies" class="btn btn-secondary">Verified Companies</a>
        <a href="/contact" class="btn btn-secondary">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
