---
// Network-monitoring style infographic, matching the reference video's
// visual language directly: hexagon hub with double rotating dashed rings,
// small hexagon "node" markers with ID tags at each connection point, and
// dashed glowing lines with a marching/flowing animation. Buyer problems
// on the left in red, supplier problems on the right in green. Pure CSS —
// no SVG measurement, no JS — every earlier bug came from trying to keep
// JS-measured elements in sync, so this sticks to fixed-width, static
// layout pieces that animate in place.
const leftItems = [
  {
    href: '/services/buyers/factory-verification',
    text: "Can't tell if a factory is even real?",
    icon: 'factory',
    id: 'BUY_01',
  },
  {
    href: '/services/buyers/quality-inspection',
    text: 'Worried about quality before it ships?',
    icon: 'check-shield',
    id: 'BUY_02',
  },
  {
    href: '/services/buyers/low-moq-knitwear',
    text: 'MOQs too high for a small brand?',
    icon: 'box',
    id: 'BUY_03',
  },
];

const rightItems = [
  {
    href: '/services/suppliers/local-representative',
    text: 'No one on the ground in Bangladesh?',
    icon: 'handshake',
    id: 'SUP_01',
  },
  {
    href: '/services/suppliers/market-entry',
    text: "Don't know where to start with BIDA?",
    icon: 'document',
    id: 'SUP_02',
  },
  {
    href: '/services/suppliers/machinery-support',
    text: 'Machinery to sell, no way to reach factories?',
    icon: 'gear',
    id: 'SUP_03',
  },
];

const icons: Record<string, string> = {
  factory: `<path d="M3 21V10l5 3V10l5 3V7l5 4v10H3z"/><path d="M3 21h18"/>`,
  'check-shield': `<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/><path d="M9 12l2 2 4-4"/>`,
  box: `<path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/><path d="M12 11v10"/>`,
  handshake: `<path d="M2 12l5-4 4 3 3-2 5 4"/><path d="M9 11l3 3-2 2"/><path d="M13 10l3 3-2 2"/>`,
  document: `<path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/><path d="M9 13h6M9 17h6M9 9h2"/>`,
  gear: `<circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M4.2 7l2.6 1.5M17.2 15.5l2.6 1.5M4.2 17l2.6-1.5M17.2 8.5l2.6-1.5M3 12h3M18 12h3"/>`,
};

const HUB_DELAY = 0.1;
const STEP = 0.18;
function delayFor(rowIndex: number, side: 'left' | 'right') {
  const slot = rowIndex * 2 + (side === 'right' ? 1 : 0);
  return (HUB_DELAY + 0.3 + slot * STEP).toFixed(2) + 's';
}
---

<div class="problem-hub">
  <!-- faint floating background hexagons, like the reference video -->
  <span class="bg-hex bg-hex-1" aria-hidden="true"></span>
  <span class="bg-hex bg-hex-2" aria-hidden="true"></span>
  <span class="bg-hex bg-hex-3" aria-hidden="true"></span>
  <span class="bg-hex bg-hex-4" aria-hidden="true"></span>

  <div class="hub-diagram">
    <div class="hub-col hub-col-left">
      {leftItems.map((item, i) => (
        <div class="hub-row">
          <a href={item.href} class="hub-pill hub-anim" style={`animation-delay: ${delayFor(i, 'left')}`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.icon]} />
            <span class="hub-pill-text">
              <span class="hub-pill-id">[{item.id}]</span>
              {item.text}
            </span>
          </a>
          <span class="hub-stub">
            <span class="hub-node"></span>
          </span>
        </div>
      ))}
    </div>

    <div class="hub-core-wrap">
      <span class="hub-ring hub-ring-outer" aria-hidden="true"></span>
      <span class="hub-ring hub-ring-inner" aria-hidden="true"></span>
      <div class="hub-core hub-anim" style={`animation-delay: ${HUB_DELAY}s`}>
        <span class="hub-core-label">THREAD<br />BRIDGE</span>
      </div>
    </div>

    <div class="hub-col hub-col-right">
      {rightItems.map((item, i) => (
        <div class="hub-row hub-row-reverse">
          <span class="hub-stub hub-stub-green">
            <span class="hub-node hub-node-green"></span>
          </span>
          <a href={item.href} class="hub-pill hub-pill-green hub-anim" style={`animation-delay: ${delayFor(i, 'right')}`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.icon]} />
            <span class="hub-pill-text">
              <span class="hub-pill-id">[{item.id}]</span>
              {item.text}
            </span>
          </a>
        </div>
      ))}
    </div>
  </div>

  <div class="hub-legend">
    <span><i class="dot dot-red"></i> For Buyers</span>
    <span><i class="dot dot-green"></i> For Suppliers</span>
  </div>
</div>

<style>
  .problem-hub {
    max-width: 1100px;
    margin: 8px auto 0;
    position: relative;
    padding: 20px 0;
  }

  /* ---- faint scattered background hexagons (atmosphere, like the video) ---- */
  .bg-hex {
    position: absolute;
    width: 28px;
    height: 28px;
    clip-path: polygon(50% 0%, 95% 25%, 95% 75%, 50% 100%, 5% 75%, 5% 25%);
    border: 1px solid var(--border-color);
    opacity: 0.5;
    z-index: -1;
  }
  .bg-hex::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--border-color);
    transform: translate(-50%, -50%);
  }
  .bg-hex-1 { top: 4%; left: 6%; width: 20px; height: 20px; }
  .bg-hex-2 { bottom: 8%; left: 14%; }
  .bg-hex-3 { top: 6%; right: 8%; width: 22px; height: 22px; }
  .bg-hex-4 { bottom: 4%; right: 16%; width: 18px; height: 18px; }

  @media (max-width: 760px) {
    .bg-hex { display: none; }
  }

  .hub-diagram {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  /* ---- hub: hexagon core + two rotating dashed rings ---- */
  .hub-core-wrap {
    position: relative;
    flex-shrink: 0;
    width: 130px;
    height: 130px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hub-ring {
    position: absolute;
    border-radius: 50%;
    border-style: dashed;
  }

  .hub-ring-outer {
    inset: -26px;
    border-width: 1.5px;
    border-color: var(--accent-color) var(--accent-color) transparent transparent;
    opacity: 0.6;
    animation: hub-spin-cw 10s linear infinite;
  }

  .hub-ring-inner {
    inset: -12px;
    border-width: 1.5px;
    border-color: transparent transparent var(--green-color) var(--green-color);
    opacity: 0.6;
    animation: hub-spin-ccw 7s linear infinite;
  }

  @keyframes hub-spin-cw {
    to { transform: rotate(360deg); }
  }

  @keyframes hub-spin-ccw {
    to { transform: rotate(-360deg); }
  }

  .hub-core {
    position: relative;
    z-index: 1;
    width: 130px;
    height: 130px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card-bg);
    border: 1.5px solid var(--accent-color);
    box-shadow: 0 0 18px -4px var(--accent-color);
    clip-path: polygon(50% 0%, 95% 25%, 95% 75%, 50% 100%, 5% 75%, 5% 25%);
  }

  .hub-core-label {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    text-align: center;
    line-height: 1.2;
  }

  .hub-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex: 1;
    min-width: 0;
    max-width: 340px;
  }

  .hub-col-left {
    align-items: flex-end;
  }

  .hub-col-right {
    align-items: flex-start;
  }

  .hub-row {
    display: flex;
    align-items: center;
    width: 100%;
    justify-content: flex-end;
  }

  .hub-row-reverse {
    justify-content: flex-start;
  }

  /* ---- connector: dashed, glowing, marching-line animation ---- */
  .hub-stub {
    flex-shrink: 0;
    width: 30px;
    height: 10px;
    position: relative;
    display: flex;
    align-items: center;
  }

  .hub-stub::before {
    content: '';
    display: block;
    width: 100%;
    height: 2px;
    background-image: repeating-linear-gradient(
      to right,
      var(--accent-color) 0 6px,
      transparent 6px 12px
    );
    background-size: 200% 100%;
    animation: dash-march 1s linear infinite;
    box-shadow: 0 0 4px var(--accent-color);
  }

  .hub-stub-green::before {
    background-image: repeating-linear-gradient(
      to right,
      var(--green-color) 0 6px,
      transparent 6px 12px
    );
    box-shadow: 0 0 4px var(--green-color);
  }

  @keyframes dash-march {
    from { background-position: 0 0; }
    to { background-position: -24px 0; }
  }

  /* small hexagon "network node" marker at the pill end of each connector */
  .hub-node {
    position: absolute;
    top: 50%;
    left: -3px;
    width: 10px;
    height: 10px;
    transform: translateY(-50%);
    clip-path: polygon(50% 0%, 95% 25%, 95% 75%, 50% 100%, 5% 75%, 5% 25%);
    background: var(--card-bg);
    border: 1.5px solid var(--accent-color);
    box-shadow: 0 0 5px var(--accent-color);
    animation: node-breathe 2.4s ease-in-out infinite;
  }

  .hub-row-reverse .hub-node {
    left: auto;
    right: -3px;
  }

  .hub-node-green {
    border-color: var(--green-color);
    box-shadow: 0 0 5px var(--green-color);
  }

  @keyframes node-breathe {
    0%, 100% { opacity: 0.7; transform: translateY(-50%) scale(1); }
    50% { opacity: 1; transform: translateY(-50%) scale(1.25); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-ring-outer,
    .hub-ring-inner,
    .hub-stub::before,
    .hub-node {
      animation: none;
    }
  }

  /* ---- pills ---- */
  .hub-pill {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    max-width: 280px;
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--card-bg);
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.3;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .hub-pill:hover {
    border-color: var(--accent-color);
    transform: translateY(-1px) scale(1.02);
    text-decoration: none;
  }

  .hub-pill-green:hover {
    border-color: var(--green-color);
  }

  .hub-pill svg {
    flex-shrink: 0;
    width: clamp(22px, 5vw, 28px);
    height: clamp(22px, 5vw, 28px);
    color: var(--accent-color);
  }

  .hub-pill-green svg {
    color: var(--green-color);
  }

  .hub-pill-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hub-pill-id {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: var(--accent-color);
    opacity: 0.7;
  }

  .hub-pill-green .hub-pill-id {
    color: var(--green-color);
  }

  .hub-legend {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 28px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 6px;
  }

  .dot-red { background: var(--accent-color); }
  .dot-green { background: var(--green-color); }

  @keyframes hub-pop-in {
    0% { opacity: 0; transform: translateY(10px) scale(0.9); }
    70% { opacity: 1; transform: translateY(-2px) scale(1.03); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hub-anim {
    opacity: 0;
    animation: hub-pop-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-anim {
      opacity: 1;
      animation: none;
    }
  }

  @media (max-width: 760px) {
    .hub-diagram {
      flex-direction: column;
      gap: 14px;
    }

    .hub-core-wrap {
      order: -1;
      margin-bottom: 14px;
      width: 110px;
      height: 110px;
    }

    .hub-core {
      width: 110px;
      height: 110px;
    }

    .hub-core-label {
      font-size: 0.9rem;
    }

    .hub-ring-outer { inset: -20px; }
    .hub-ring-inner { inset: -9px; }

    .hub-col,
    .hub-col-left,
    .hub-col-right {
      max-width: none;
      align-items: stretch;
      width: 100%;
      gap: 12px;
    }

    .hub-row,
    .hub-row-reverse {
      justify-content: stretch;
    }

    .hub-stub {
      display: none;
    }

    .hub-pill {
      max-width: none;
      width: 100%;
    }
  }
</style>
