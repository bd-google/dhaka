---
// Self-hosted, zero-image infographic: 7 clickable process tiles built from
// inline SVG (no external requests, no raster images) connected by a flow
// line. Each tile links straight to the relevant service or directory page.
const tiles = [
  {
    href: '/services/buyers/factory-verification',
    label: 'Factory Verification',
    audience: 'Buyers',
    icon: 'factory',
  },
  {
    href: '/services/buyers/quality-inspection',
    label: 'Quality Inspection',
    audience: 'Buyers',
    icon: 'check-shield',
  },
  {
    href: '/services/buyers/sample-development',
    label: 'Sample & Bulk',
    audience: 'Buyers',
    icon: 'box',
  },
  {
    href: '/companies',
    label: 'Verified Companies',
    audience: 'Directory',
    icon: 'stamp',
  },
  {
    href: '/services/suppliers/local-representative',
    label: 'Local Representation',
    audience: 'Suppliers',
    icon: 'handshake',
  },
  {
    href: '/services/suppliers/machinery-support',
    label: 'Machinery & Fabric',
    audience: 'Suppliers',
    icon: 'gear',
  },
  {
    href: '/services/suppliers/market-entry',
    label: 'Market Entry',
    audience: 'Suppliers',
    icon: 'document',
  },
];

const icons: Record<string, string> = {
  factory: `<path d="M3 21V10l5 3V10l5 3V7l5 4v10H3z"/><path d="M3 21h18"/>`,
  'check-shield': `<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/><path d="M9 12l2 2 4-4"/>`,
  box: `<path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/><path d="M12 11v10"/>`,
  stamp: `<circle cx="12" cy="9" r="5"/><path d="M9 9l2 2 4-4"/><path d="M8 20l1.5-5h5L16 20"/>`,
  handshake: `<path d="M2 12l5-4 4 3 3-2 5 4"/><path d="M9 11l3 3-2 2"/><path d="M13 10l3 3-2 2"/>`,
  gear: `<circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M4.2 7l2.6 1.5M17.2 15.5l2.6 1.5M4.2 17l2.6-1.5M17.2 8.5l2.6-1.5M3 12h3M18 12h3"/>`,
  document: `<path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/><path d="M9 13h6M9 17h6M9 9h2"/>`,
};
---

<div class="hero-flow" role="list" aria-label="Thread Bridge services overview">
  {tiles.map((tile, i) => (
    <>
      <a href={tile.href} class="flow-tile" role="listitem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[tile.icon]} />
        <span class="flow-audience">{tile.audience}</span>
        <span class="flow-label">{tile.label}</span>
      </a>
      {i < tiles.length - 1 && <span class="flow-connector" aria-hidden="true"></span>}
    </>
  ))}
</div>

<style>
  .hero-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 0;
    margin: 48px auto 0;
    max-width: 1100px;
  }

  .flow-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 128px;
    padding: 16px 8px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    color: var(--text-primary);
    text-decoration: none;
    background: var(--card-bg);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .flow-tile:hover {
    border-color: var(--accent-color);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .flow-tile svg {
    width: 28px;
    height: 28px;
    color: var(--accent-color);
  }

  .flow-tile:nth-child(8n+4) svg,
  .flow-tile:nth-child(8n+9) svg {
    color: var(--green-color);
  }

  .flow-audience {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .flow-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.2;
  }

  .flow-connector {
    align-self: center;
    width: 20px;
    height: 1px;
    background: var(--border-color);
    margin: 0 4px;
  }

  @media (max-width: 900px) {
    .hero-flow {
      gap: 12px;
    }
    .flow-connector {
      display: none;
    }
    .flow-tile {
      width: 104px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-tile {
      transition: none;
    }
  }
</style>
