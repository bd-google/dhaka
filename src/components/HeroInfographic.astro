---
// Network-monitoring infographic matching the reference video precisely:
// small glowing hexagon "nodes" (no box/border around the text — the text
// floats next to the node exactly like the video), a colored underscore-
// style slug label above the question, a gray monospace [ID] tag below,
// dashed marching-line connectors, and a hexagon hub with two counter-
// rotating dashed rings. Buyer problems red/left, supplier problems
// green/right. Pure CSS, no JS — fixed-size pieces only, nothing measured
// at runtime, so nothing can drift out of alignment.
const leftItems = [
  {
    href: '/services/buyers/factory-verification',
    slug: 'FACTORY_VERIFY',
    text: "Can't tell if a factory is even real?",
    id: 'BUY_01',
    icon: 'factory',
  },
  {
    href: '/services/buyers/quality-inspection',
    slug: 'QUALITY_CHECK',
    text: 'Worried about quality before it ships?',
    id: 'BUY_02',
    icon: 'check-shield',
  },
  {
    href: '/services/buyers/low-moq-knitwear',
    slug: 'LOW_MOQ',
    text: 'MOQs too high for a small brand?',
    id: 'BUY_03',
    icon: 'box',
  },
];

const rightItems = [
  {
    href: '/services/suppliers/local-representative',
    slug: 'LOCAL_REP',
    text: 'No one on the ground in Bangladesh?',
    id: 'SUP_01',
    icon: 'handshake',
  },
  {
    href: '/services/suppliers/market-entry',
    slug: 'BIDA_ENTRY',
    text: "Don't know where to start with BIDA?",
    id: 'SUP_02',
    icon: 'document',
  },
  {
    href: '/services/suppliers/machinery-support',
    slug: 'MACHINERY_SALES',
    text: 'Machinery to sell, no way to reach factories?',
    id: 'SUP_03',
    icon: 'gear',
  },
];

const icons: Record<string, string> = {
  factory: `<path d="M3 21V10l5 3V10l5 3V7l5 4v10H3z"/><path d="M3 21h18"/>`,
  'check-shield': `<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/><path d="M9 12l2 2 4-4"/>`,
  box: `<path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/><path d="M12 11v10"/>`,
  handshake: `<path d="M2 12l5-4 4 3 3-2 5 4"/><path d="M9 11l3 3-2 2"/><path d="M13 10l3 3-2 2"/>`,
  document: `<path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/><path d="M9 13h6M9 17h6M9 9h2"/>`,
  gear: `<circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M4.2 7l2.6 1.5M17.2 15.5l2.6 1.5M4.2 17l2.6-1.5M17.2 8.5l2.6-1.5M3 12h3M18 12h3"/>`,
};

const HUB_DELAY = 0.1;
const STEP = 0.18;
function delayFor(rowIndex: number, side: 'left' | 'right') {
  const slot = rowIndex * 2 + (side === 'right' ? 1 : 0);
  return (HUB_DELAY + 0.3 + slot * STEP).toFixed(2) + 's';
}
---

<div class="problem-hub">
  <span class="bg-hex bg-hex-1" aria-hidden="true"></span>
  <span class="bg-hex bg-hex-2" aria-hidden="true"></span>
  <span class="bg-hex bg-hex-3" aria-hidden="true"></span>
  <span class="bg-hex bg-hex-4" aria-hidden="true"></span>

  <div class="hub-diagram">
    <div class="hub-col hub-col-left">
      {leftItems.map((item, i) => (
        <div class="hub-row">
          <a href={item.href} class="hub-node-link hub-anim" style={`animation-delay: ${delayFor(i, 'left')}`}>
            <span class="node-text node-text-left">
              <span class="node-question">{item.text}</span>
            </span>
          </a>
        </div>
      ))}
    </div>

    <div class="hub-core-wrap hub-anim" style={`animation-delay: ${HUB_DELAY}s`}>
      <dotlottie-wc
        src="https://lottie.host/eef3f6bd-535b-4aac-911a-3f6c65bc9f7f/hr0omEw2Y8.lottie"
        autoplay
        loop
        style="width: 220px; height: 220px;"
      ></dotlottie-wc>
    </div>

    <div class="hub-col hub-col-right">
      {rightItems.map((item, i) => (
        <div class="hub-row hub-row-reverse">
          <a href={item.href} class="hub-node-link hub-node-link-green hub-anim" style={`animation-delay: ${delayFor(i, 'right')}`}>
            <span class="node-text node-text-right">
              <span class="node-question">{item.text}</span>
            </span>
          </a>
        </div>
      ))}
    </div>
  </div>

  <div class="hub-legend">
    <span><i class="dot dot-red"></i> For Buyers</span>
    <span><i class="dot dot-green"></i> For Suppliers</span>
  </div>
</div>

<style>
  .problem-hub {
    max-width: 1140px;
    margin: 8px auto 0;
    position: relative;
    padding: 24px 0;
  }

  .bg-hex {
    position: absolute;
    width: 24px;
    height: 24px;
    clip-path: polygon(50% 0%, 95% 25%, 95% 75%, 50% 100%, 5% 75%, 5% 25%);
    border: 1px solid var(--border-color);
    opacity: 0.5;
    z-index: -1;
  }
  .bg-hex::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--border-color);
    transform: translate(-50%, -50%);
  }
  .bg-hex-1 { top: 2%; left: 4%; }
  .bg-hex-2 { bottom: 4%; left: 12%; width: 18px; height: 18px; }
  .bg-hex-3 { top: 4%; right: 6%; width: 20px; height: 20px; }
  .bg-hex-4 { bottom: 2%; right: 14%; width: 16px; height: 16px; }

  @media (max-width: 760px) {
    .bg-hex { display: none; }
  }

  .hub-diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  /* ---- hub: now rendered by the real Lottie animation, this wrapper
     just sizes/positions it ---- */
  .hub-core-wrap {
    position: relative;
    flex-shrink: 0;
    width: 220px;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
  }


  /* ---- columns ---- */
  .hub-col {
    display: flex;
    flex-direction: column;
    gap: 22px;
    flex: 1;
    min-width: 0;
    max-width: 360px;
  }

  .hub-col-left { align-items: flex-end; }
  .hub-col-right { align-items: flex-start; }

  /* Bordered panel around each group of 3 — desktop/tablet only.
     Mobile keeps its existing plain layout untouched, as requested. */
  @media (min-width: 761px) {
    .hub-col-left {
      border: 1.5px solid var(--accent-color);
      border-radius: 6px;
      padding: 24px 28px;
    }

    .hub-col-right {
      border: 1.5px solid var(--green-color);
      border-radius: 6px;
      padding: 24px 28px;
    }
  }

  .hub-row {
    display: flex;
    align-items: center;
    width: 100%;
    justify-content: flex-end;
  }

  .hub-row-reverse { justify-content: flex-start; }

  /* ---- node link: plain text, no box, no separate connector — the
     Lottie animation itself already draws its own dot+line, so a second
     hand-coded connector was redundant and looked like stray dash marks
     at small sizes ---- */
  .hub-node-link {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 280px;
    padding: 6px 4px;
    text-decoration: none;
    color: inherit;
  }

  .node-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .node-text-left { text-align: right; align-items: flex-end; }
  .node-text-right { text-align: left; align-items: flex-start; }

  .node-slug {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--accent-color);
    opacity: 0.85;
  }

  .node-slug-green { color: var(--green-color); }

  .node-question {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .node-text-left .node-question { flex-direction: row-reverse; }

  .node-question svg {
    flex-shrink: 0;
    width: clamp(18px, 4vw, 22px);
    height: clamp(18px, 4vw, 22px);
    color: var(--text-secondary);
  }

  .node-id {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .hub-node-link:hover .node-question {
    color: var(--accent-color);
  }

  .hub-node-link-green:hover .node-question {
    color: var(--green-color);
  }

  .hub-legend {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 28px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 6px;
  }

  .dot-red { background: var(--accent-color); }
  .dot-green { background: var(--green-color); }

  @keyframes hub-pop-in {
    0% { opacity: 0; transform: translateY(10px) scale(0.9); }
    70% { opacity: 1; transform: translateY(-2px) scale(1.03); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hub-anim {
    opacity: 0;
    animation: hub-pop-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-anim { opacity: 1; animation: none; }
  }

  @media (max-width: 760px) {
    .problem-hub {
      padding: 12px 0;
    }

    .hub-diagram {
      gap: 2px;
      align-items: center;
    }

    .hub-core-wrap {
      width: 130px;
      height: 130px;
      flex-shrink: 0;
    }

    .hub-core-wrap dotlottie-wc {
      width: 130px !important;
      height: 130px !important;
    }

    .hub-col {
      gap: 16px;
      max-width: none;
    }

    .hub-node-link {
      max-width: none;
      gap: 6px;
      padding: 2px;
    }

    .node-question {
      font-size: 0.74rem;
      line-height: 1.3;
    }
  }

  /* Very narrow phones: trim a little further */
  @media (max-width: 400px) {
    .hub-core-wrap {
      width: 110px;
      height: 110px;
    }

    .hub-core-wrap dotlottie-wc {
      width: 110px !important;
      height: 110px !important;
    }

    .node-question {
      font-size: 0.7rem;
    }
  }
</style>

<script>
  // Registers <dotlottie-wc>. Bundled by Astro/Vite from the npm package
  // (self-hosted, no external <script src> tag) — only the animation data
  // itself is fetched at runtime from lottie.host, same as any embedded
  // video or font would be.
  import '@lottiefiles/dotlottie-wc';
</script>
