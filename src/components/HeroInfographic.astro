---
// Problem-first hub-and-spoke infographic: a central "Thread Bridge" hub
// with two flowing curved lines branching out — red toward three buyer
// pain-points, green toward three supplier pain-points. The curves are
// drawn with a small deferred vanilla-JS pass (measures real element
// positions, builds a smooth SVG path) so they stay pixel-perfect at any
// screen width; everything else (icons, pills) is static markup/CSS.
// No frameworks, no images, script is deferred so it never blocks paint.
const leftItems = [
  {
    href: '/services/buyers/factory-verification',
    text: "Can't tell if a factory is even real?",
    icon: 'factory',
  },
  {
    href: '/services/buyers/quality-inspection',
    text: 'Worried about quality before it ships?',
    icon: 'check-shield',
  },
  {
    href: '/services/buyers/low-moq-knitwear',
    text: 'MOQs too high for a small brand?',
    icon: 'box',
  },
];

const rightItems = [
  {
    href: '/services/suppliers/local-representative',
    text: 'No one on the ground in Bangladesh?',
    icon: 'handshake',
  },
  {
    href: '/services/suppliers/market-entry',
    text: "Don't know where to start with BIDA?",
    icon: 'document',
  },
  {
    href: '/services/suppliers/machinery-support',
    text: 'Machinery to sell, no way to reach factories?',
    icon: 'gear',
  },
];

const icons: Record<string, string> = {
  factory: `<path d="M3 21V10l5 3V10l5 3V7l5 4v10H3z"/><path d="M3 21h18"/>`,
  'check-shield': `<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/><path d="M9 12l2 2 4-4"/>`,
  box: `<path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/><path d="M12 11v10"/>`,
  handshake: `<path d="M2 12l5-4 4 3 3-2 5 4"/><path d="M9 11l3 3-2 2"/><path d="M13 10l3 3-2 2"/>`,
  document: `<path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/><path d="M9 13h6M9 17h6M9 9h2"/>`,
  gear: `<circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M4.2 7l2.6 1.5M17.2 15.5l2.6 1.5M4.2 17l2.6-1.5M17.2 8.5l2.6-1.5M3 12h3M18 12h3"/>`,
};
---

<div class="problem-hub" id="problem-hub">
  <p class="hub-eyebrow">Which of these sounds familiar?</p>

  <div class="hub-diagram" id="hub-diagram">
    <svg class="hub-curves" id="hub-curves" aria-hidden="true">
      <defs>
        <linearGradient id="curve-red" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="var(--accent-color)" stop-opacity="0.15" />
          <stop offset="100%" stop-color="var(--accent-color)" stop-opacity="0.9" />
        </linearGradient>
        <linearGradient id="curve-green" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="var(--green-color)" stop-opacity="0.15" />
          <stop offset="100%" stop-color="var(--green-color)" stop-opacity="0.9" />
        </linearGradient>
      </defs>
      <path id="path-left" fill="none" stroke="url(#curve-red)" stroke-width="1.5" />
      <path id="path-right" fill="none" stroke="url(#curve-green)" stroke-width="1.5" />
      <g id="dots-left"></g>
      <g id="dots-right"></g>
    </svg>

    <div class="hub-col hub-col-left">
      {leftItems.map((item, i) => (
        <div class="hub-row" style={`--d: ${i * 0.08}s`}>
          <a href={item.href} class="hub-pill hub-anim hub-anim-left">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.icon]} />
            <span>{item.text}</span>
          </a>
          <span class="hub-anchor" data-side="left"></span>
        </div>
      ))}
    </div>

    <div class="hub-core hub-anim hub-anim-core" id="hub-core">
      <span class="hub-core-label">Thread<br />Bridge</span>
    </div>

    <div class="hub-col hub-col-right">
      {rightItems.map((item, i) => (
        <div class="hub-row hub-row-reverse" style={`--d: ${i * 0.08}s`}>
          <span class="hub-anchor" data-side="right"></span>
          <a href={item.href} class="hub-pill hub-pill-green hub-anim hub-anim-right">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.icon]} />
            <span>{item.text}</span>
          </a>
        </div>
      ))}
    </div>
  </div>

  <div class="hub-legend">
    <span><i class="dot dot-red"></i> For Buyers</span>
    <span><i class="dot dot-green"></i> For Suppliers</span>
  </div>
</div>

<script>
  // Draws two smooth curves (hub -> 3 buyer pills, hub -> 3 supplier pills)
  // by measuring real DOM positions. Runs after load, on resize (debounced),
  // and once more after fonts settle. No external deps, ~1KB of JS.
  function buildSmoothPath(points: { x: number; y: number }[]): string {
    if (points.length === 0) return '';
    if (points.length === 1) return `M ${points[0].x} ${points[0].y}`;
    let d = `M ${points[0].x} ${points[0].y}`;
    for (let i = 0; i < points.length - 1; i++) {
      const p0 = points[i];
      const p1 = points[i + 1];
      const midX = (p0.x + p1.x) / 2;
      d += ` C ${midX} ${p0.y}, ${midX} ${p1.y}, ${p1.x} ${p1.y}`;
    }
    return d;
  }

  function drawDots(group: SVGGElement | null, points: { x: number; y: number }[], color: string) {
    if (!group) return;
    group.innerHTML = '';
    points.forEach((p) => {
      const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      c.setAttribute('cx', String(p.x));
      c.setAttribute('cy', String(p.y));
      c.setAttribute('r', '3');
      c.setAttribute('fill', color);
      group.appendChild(c);
    });
  }

  function drawHubDiagram() {
    const container = document.getElementById('hub-diagram');
    const svg = document.getElementById('hub-curves') as SVGSVGElement | null;
    const hub = document.getElementById('hub-core');
    if (!container || !svg || !hub) return;

    // Only draw the curved-line version above the mobile breakpoint —
    // below it the CSS fallback (plain stacked list) takes over and the
    // SVG is hidden, so skip the work entirely to save a few cycles.
    if (window.innerWidth <= 760) {
      svg.style.display = 'none';
      return;
    }
    svg.style.display = 'block';

    const containerRect = container.getBoundingClientRect();
    svg.setAttribute('viewBox', `0 0 ${containerRect.width} ${containerRect.height}`);
    svg.setAttribute('width', String(containerRect.width));
    svg.setAttribute('height', String(containerRect.height));

    const hubRect = hub.getBoundingClientRect();
    const hubLeftAnchor = {
      x: hubRect.left - containerRect.left,
      y: hubRect.top - containerRect.top + hubRect.height / 2,
    };
    const hubRightAnchor = {
      x: hubRect.right - containerRect.left,
      y: hubRect.top - containerRect.top + hubRect.height / 2,
    };

    const leftAnchors = Array.from(container.querySelectorAll('.hub-anchor[data-side="left"]')) as HTMLElement[];
    const rightAnchors = Array.from(container.querySelectorAll('.hub-anchor[data-side="right"]')) as HTMLElement[];

    const leftPoints = leftAnchors.map((el) => {
      const r = el.getBoundingClientRect();
      return { x: r.left - containerRect.left, y: r.top - containerRect.top + r.height / 2 };
    });
    const rightPoints = rightAnchors.map((el) => {
      const r = el.getBoundingClientRect();
      return { x: r.left - containerRect.left, y: r.top - containerRect.top + r.height / 2 };
    });

    // Path order: hub -> topmost -> ... -> bottommost, so the curve reads
    // top-to-bottom same as the pills.
    const pathLeft = document.getElementById('path-left');
    const pathRight = document.getElementById('path-right');
    if (pathLeft) pathLeft.setAttribute('d', buildSmoothPath([hubLeftAnchor, ...leftPoints]));
    if (pathRight) pathRight.setAttribute('d', buildSmoothPath([hubRightAnchor, ...rightPoints]));

    drawDots(document.getElementById('dots-left') as SVGGElement | null, leftPoints, 'var(--accent-color)');
    drawDots(document.getElementById('dots-right') as SVGGElement | null, rightPoints, 'var(--green-color)');
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  function scheduleRedraw() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(drawHubDiagram, 100);
  }

  drawHubDiagram();
  window.addEventListener('resize', scheduleRedraw);
  window.addEventListener('load', drawHubDiagram);
  if ((document as any).fonts && (document as any).fonts.ready) {
    (document as any).fonts.ready.then(drawHubDiagram);
  }
</script>

<style>
  .problem-hub {
    max-width: 1100px;
    margin: 8px auto 0;
  }

  .hub-eyebrow {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .hub-diagram {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .hub-curves {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hub-core {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 130px;
    height: 130px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card-bg);
    border: 1.5px solid var(--accent-color);
    clip-path: polygon(50% 0%, 95% 25%, 95% 75%, 50% 100%, 5% 75%, 5% 25%);
    margin: 0 -1px;
  }

  .hub-core-label {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.05rem;
    letter-spacing: 0.03em;
    text-align: center;
    line-height: 1.15;
  }

  .hub-col {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 18px;
    flex: 1;
    min-width: 0;
    max-width: 340px;
  }

  .hub-col-left {
    align-items: flex-end;
  }

  .hub-col-right {
    align-items: flex-start;
  }

  .hub-row {
    display: flex;
    align-items: center;
    gap: 0;
    width: 100%;
    justify-content: flex-end;
  }

  .hub-row-reverse {
    justify-content: flex-start;
  }

  /* Zero-size marker the JS measures to know exactly where each curve
     should terminate — sits right at the pill's edge facing the hub. */
  .hub-anchor {
    width: 24px;
    height: 1px;
    flex-shrink: 0;
  }

  .hub-pill {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 260px;
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    background: var(--card-bg);
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.25;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .hub-pill:hover {
    border-color: var(--accent-color);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .hub-pill-green:hover {
    border-color: var(--green-color);
  }

  .hub-pill svg {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--accent-color);
  }

  .hub-pill-green svg {
    color: var(--green-color);
  }

  .hub-legend {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 28px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 6px;
  }

  .dot-red { background: var(--accent-color); }
  .dot-green { background: var(--green-color); }

  @keyframes hub-fade-in {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hub-anim {
    opacity: 0;
    animation: hub-fade-in 0.5s ease-out forwards;
  }

  .hub-anim-core {
    animation-delay: 0.05s;
  }

  .hub-anim-left,
  .hub-anim-right {
    animation-delay: calc(0.2s + var(--d, 0s));
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-anim {
      opacity: 1;
      animation: none;
    }
  }

  @media (max-width: 760px) {
    .hub-curves {
      display: none;
    }

    .hub-diagram {
      flex-direction: column;
      gap: 10px;
      position: relative;
      padding-left: 14px;
    }

    .hub-diagram::before {
      content: '';
      position: absolute;
      left: 0;
      top: 8px;
      bottom: 8px;
      width: 1px;
      background: var(--border-color);
    }

    .hub-core {
      order: -1;
      margin-bottom: 8px;
      margin-left: -14px;
      width: 110px;
      height: 110px;
    }

    .hub-core-label {
      font-size: 0.9rem;
    }

    .hub-col,
    .hub-col-left,
    .hub-col-right {
      max-width: none;
      align-items: stretch;
      width: 100%;
      gap: 10px;
    }

    .hub-row,
    .hub-row-reverse {
      justify-content: stretch;
    }

    .hub-anchor {
      display: none;
    }

    .hub-pill {
      max-width: none;
      width: 100%;
      padding: 12px 14px;
    }
  }
</style>
