---
import { siteMeta } from '../data/siteMeta';
const currentYear = new Date().getFullYear();

const companyLinks = [
  { name: 'About', url: '/about' },
  { name: 'How It Works', url: '/how-it-works' },
  { name: 'Verified Companies', url: '/companies' },
  { name: 'Case Studies', url: '/case-studies' },
  { name: 'Blog', url: '/blog' },
  { name: 'Glossary', url: '/glossary' },
  { name: 'FAQ', url: '/faq' },
  { name: 'Contact', url: '/contact' },
];

const bdBodies = [
  { name: 'Ministry of Commerce, Bangladesh', url: 'https://mincom.gov.bd/' },
  { name: 'BGMEA', url: 'https://www.bgmea.com.bd/' },
  { name: 'BKMEA', url: 'https://www.bkmea.com/' },
  { name: 'BEPZA', url: 'https://bepza.gov.bd/' },
  { name: 'BIDA', url: 'https://bida.gov.bd/' },
  { name: 'RJSC', url: 'https://roc.gov.bd/' },
];

const cnBodies = [
  { name: 'Ministry of Commerce, China (MOFCOM)', url: 'https://english.mofcom.gov.cn/' },
  { name: 'CCPIT', url: 'https://en.ccpit.org/' },
  { name: 'Chinese Embassy in Bangladesh', url: 'https://bd.china-embassy.gov.cn/eng/' },
];

const toolsLinks = [
  { name: 'Sitemap', url: '/sitemap-index.xml' },
  { name: 'Verify a Company', url: '/companies' },
  { name: 'Privacy Policy', url: '/privacy-policy' },
  { name: 'Terms of Service', url: '/terms' },
  ...siteMeta.social,
];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-col footer-about">
      <h2 style="font-size: 1.2rem; margin-bottom: 1rem;">{siteMeta.businessName}</h2>
      <p style="font-size: 0.9rem;">{siteMeta.description}</p>
      <p style="font-size: 0.85rem; margin-top: 12px;">{siteMeta.contact.address}</p>
      <p style="font-size: 0.85rem;"><a href={`mailto:${siteMeta.contact.email}`}>{siteMeta.contact.email}</a></p>
    </div>

    <details class="footer-col" open>
      <summary class="eyebrow">Company</summary>
      <ul class="footer-list">
        {companyLinks.map(l => <li><a href={l.url}>{l.name}</a></li>)}
      </ul>
    </details>

    <details class="footer-col" open>
      <summary class="eyebrow">Bangladesh — Official Bodies</summary>
      <ul class="footer-list">
        {bdBodies.map(b => <li><a href={b.url} target="_blank" rel="noopener noreferrer nofollow">{b.name}</a></li>)}
      </ul>
    </details>

    <details class="footer-col" open>
      <summary class="eyebrow" style="color: var(--green-color);">China — Official Bodies</summary>
      <ul class="footer-list">
        {cnBodies.map(b => <li><a href={b.url} target="_blank" rel="noopener noreferrer nofollow" style="color: var(--green-color);">{b.name}</a></li>)}
      </ul>
    </details>

    <details class="footer-col" open>
      <summary class="eyebrow">Sitemap & Tools</summary>
      <ul class="footer-list">
        {toolsLinks.map(l => <li><a href={l.url} target={l.url.startsWith('http') ? '_blank' : undefined} rel={l.url.startsWith('http') ? 'noopener noreferrer' : undefined}>{l.name}</a></li>)}
      </ul>
    </details>
  </div>

  <p class="container" style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 10px; margin-bottom: 0;">
    These are official third-party government and trade-association websites, listed for reference. {siteMeta.businessName} is independent and not affiliated with these bodies.
  </p>

  <div class="container footer-bottom">
    <p>&copy; {currentYear} {siteMeta.businessName}. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-color);
    padding: 60px 0 30px;
    margin-top: 80px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(4, 1fr);
    gap: 32px;
  }

  .footer-col {
    min-width: 0;
  }

  .footer-list {
    list-style: none;
    font-size: 0.85rem;
  }

  .footer-list li {
    margin-bottom: 8px;
  }

  /* On desktop the accordion chrome is invisible — columns just sit open */
  summary.eyebrow {
    cursor: default;
    list-style: none;
  }
  summary.eyebrow::-webkit-details-marker { display: none; }
  summary.eyebrow::marker { content: ''; }

  .footer-bottom {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--border-color);
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  /* Mobile: collapse each column into a native accordion, like Google's
     mobile footer — tap the label to expand/collapse, zero JS needed. */
  @media (max-width: 900px) {
    .footer-grid {
      display: block;
    }

    .footer-about {
      margin-bottom: 24px;
    }

    .footer-col {
      border-top: 1px solid var(--border-color);
    }

    .footer-col:last-child {
      border-bottom: 1px solid var(--border-color);
    }

    summary.eyebrow {
      cursor: pointer;
      padding: 16px 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    summary.eyebrow::after {
      content: '+';
      font-family: var(--font-mono);
      font-size: 1rem;
      color: var(--text-secondary);
    }

    details[open] summary.eyebrow::after {
      content: '−';
    }

    .footer-list {
      padding-bottom: 16px;
    }
  }
</style>


