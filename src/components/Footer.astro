---
import { siteMeta } from '../data/siteMeta';
const currentYear = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--border-color); padding: 60px 0 40px; margin-top: 80px;">
  <div class="container grid grid-2-tablet grid-3-desktop">
    <div>
      <h2 style="font-size: 1.2rem; margin-bottom: 1rem;">{siteMeta.businessName}</h2>
      <p style="font-size: 0.9rem;">{siteMeta.description}</p>
    </div>

    <div>
      <h3 style="font-size: 1rem; margin-bottom: 1rem;">Contact</h3>
      <p style="font-size: 0.9rem; margin-bottom: 0.5rem;">{siteMeta.contact.address}</p>
      <p style="font-size: 0.9rem; margin-bottom: 0.5rem;"><a href={`mailto:${siteMeta.contact.email}`}>{siteMeta.contact.email}</a></p>
      <p style="font-size: 0.9rem;"><a href={`tel:${siteMeta.contact.phone}`}>{siteMeta.contact.phone}</a></p>
    </div>

    <div>
      <h3 style="font-size: 1rem; margin-bottom: 1rem;">Links</h3>
      <ul style="list-style: none; font-size: 0.9rem;">
        <li style="margin-bottom: 0.5rem;"><a href="/sitemap-index.xml">Sitemap</a></li>
        {siteMeta.social.map(link => (
          <li style="margin-bottom: 0.5rem;"><a href={link.url} target="_blank" rel="noopener noreferrer">{link.name}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container" style="margin-top: 40px; padding-top: 20px; border-top: 1px solid var(--border-color); font-size: 0.8rem; color: var(--text-secondary);">
    <p>&copy; {currentYear} {siteMeta.businessName}. All rights reserved.</p>
  </div>
</footer>
